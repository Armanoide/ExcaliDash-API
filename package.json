{
  "name": "excalidash-api",
  "version": "2.0.0",
  "description": "Excalidash programmatic diagram creation API with JWT auth",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.0",
    "swagger-jsdoc": "^6.2.8",
    "@scalar/api-reference": "^1.27.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dagre": "^0.7.52",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.0",
    "@types/pg": "^8.11.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
