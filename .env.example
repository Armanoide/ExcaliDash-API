# ExcaliDash API Environment Variables

# Excalidash backend URL (container name or hostname)
BACKEND_URL=excalidash_backend:8000

# PostgreSQL connection string
DATABASE_URL=postgresql://excalidash:excalidash@excalidash_postgres:5432/excalidash

# JWT secret for signing tokens (REQUIRED, use a strong random string)
JWT_SECRET=your-secret-here-change-in-production

# Frontend URL for CORS and share links
FRONTEND_URL=https://draw.example.com

# JWT token expiration (e.g., 15m, 1h, 4h, 24h)
API_JWT_EXPIRES_IN=1h

# Refresh token expiration (e.g., 7d, 30d)
API_REFRESH_EXPIRES_IN=7d

# Server port
PORT=3000

# Request timeout in milliseconds
REQUEST_TIMEOUT=15000

# Log level (error, warn, info, debug)
LOG_LEVEL=info
